<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_dark">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="16dp"
        android:background="@color/bg_surface">

        <TextView
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="Debug log"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary" />

        <Button
            android:id="@+id/btnClose"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Close"
            android:textColor="@color/text_primary"
            android:background="@android:color/transparent" />
    </LinearLayout>

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:padding="8dp"
        android:background="@color/bg_dark">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/filterAll"
                style="@style/CouchFlowDebugChip"
                android:text="All" />

            <TextView
                android:id="@+id/filterErrors"
                style="@style/CouchFlowDebugChip"
                android:text="Errors" />

            <TextView
                android:id="@+id/filterConsole"
                style="@style/CouchFlowDebugChip"
                android:text="Console" />

            <TextView
                android:id="@+id/filterBridge"
                style="@style/CouchFlowDebugChip"
                android:text="Bridge" />

            <TextView
                android:id="@+id/filterFetch"
                style="@style/CouchFlowDebugChip"
                android:text="Fetch" />

            <TextView
                android:id="@+id/filterFs"
                style="@style/CouchFlowDebugChip"
                android:text="FS" />
        </LinearLayout>
    </HorizontalScrollView>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@color/bg_dark">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/debugList"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingBottom="16dp" />

        <TextView
            android:id="@+id/debugEmpty"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="No events yet."
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:visibility="gone"
            tools:visibility="visible" />
    </FrameLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="8dp"
        android:background="@color/bg_surface">

        <Button
            android:id="@+id/btnClear"
            style="@style/CouchFlowDebugButton"
            android:text="Clear" />

        <Button
            android:id="@+id/btnCopy"
            style="@style/CouchFlowDebugButton"
            android:text="Copy" />

        <Button
            android:id="@+id/btnShare"
            style="@style/CouchFlowDebugButton"
            android:text="Share" />

        <Button
            android:id="@+id/btnSave"
            style="@style/CouchFlowDebugButton"
            android:text="Save" />
    </LinearLayout>

</LinearLayout>